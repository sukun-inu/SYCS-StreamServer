# ── RTMP Ingest ──────────────────────────────────────────────────────────────
RTMP_PORT=1935

# ── NVENC Encoding ───────────────────────────────────────────────────────────
VIDEO_BITRATE=4000k        # GTX1650 上限目安: 8000k
AUDIO_BITRATE=128k

# ── LL-HLS Tuning ────────────────────────────────────────────────────────────
# セグメント長(秒): 小さいほど低遅延だがサーバー負荷増。0.5 推奨
HLS_SEGMENT_TIME=0.5
# パーツ長(秒): LL-HLS の最小配信単位。0.1 で ~100ms 粒度
HLS_PART_DURATION=0.1
# プレイリスト保持セグメント数
HLS_LIST_SIZE=6

# ── API Server ────────────────────────────────────────────────────────────────
API_PORT=8080
LOG_LEVEL=info             # debug / info / warning / error
