# ============================================================
#  SYCS Stream Server — 環境変数設定
#  このファイルを .env にコピーして値を埋めてください。
#  Portainer を使う場合は Environment Variables 欄に直接貼り付けてください。
# ============================================================

# ── ngrok 認証 ───────────────────────────────────────────────────────────────
# https://dashboard.ngrok.com/get-started/your-authtoken で取得
NGROK_AUTHTOKEN=your_ngrok_authtoken_here

# ngrok トンネルのターゲット (変更不要な場合が多い)
NGROK_HLS_TARGET=sycs-api-server:8080
NGROK_RTMP_TARGET=sycs-media-server:1935

# ngrok 管理 Web UI のホスト公開ポート
NGROK_HLS_UI_PORT=4040
NGROK_RTMP_UI_PORT=4041

# FastAPI が ngrok API を参照する内部 URL (コンテナ名が変わる場合のみ変更)
NGROK_HLS_API=http://ngrok-hls:4040
NGROK_RTMP_API=http://ngrok-rtmp:4040

# ngrok URL のキャッシュ有効時間 (秒)
NGROK_CACHE_TTL=30

# ── RTMP Ingest ──────────────────────────────────────────────────────────────
RTMP_PORT=1935

# ── NVENC エンコード ──────────────────────────────────────────────────────────
# GTX1650 の実用上限: VIDEO_BITRATE=8000k 程度
VIDEO_BITRATE=4000k
AUDIO_BITRATE=128k

# ── LL-HLS チューニング ───────────────────────────────────────────────────────
# セグメント長 (秒): 小さいほど低遅延・負荷増。PC/Android 共通
HLS_SEGMENT_TIME=0.5
# パーツ長 (秒): PC 向け LL-HLS の最小配信単位
HLS_PART_DURATION=0.1
# プレイリスト保持セグメント数
HLS_LIST_SIZE=6

# ── API Server ────────────────────────────────────────────────────────────────
API_PORT=8080
LOG_LEVEL=info              # debug / info / warning / error

# ── Docker 共通 ───────────────────────────────────────────────────────────────
RESTART_POLICY=unless-stopped

# ── GPU (通常は変更不要) ──────────────────────────────────────────────────────
CUDA_VERSION=12.3.1-runtime-ubuntu22.04
GPU_COUNT=1

# ── ヘルスチェック (通常は変更不要) ──────────────────────────────────────────
HC_INTERVAL=10s
HC_TIMEOUT=5s
HC_RETRIES=3

# ── コンテナ名 (複数スタックを同一ホストで動かす場合に変更) ─────────────────
MEDIA_CONTAINER=sycs-media-server
API_CONTAINER=sycs-api-server
NGROK_HLS_CONTAINER=sycs-ngrok-hls
NGROK_RTMP_CONTAINER=sycs-ngrok-rtmp
