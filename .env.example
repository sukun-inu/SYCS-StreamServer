# ============================================================
#  SYCS Stream Server — 環境変数設定
#  このファイルを .env にコピーして値を埋めてください。
#  Portainer を使う場合は Environment Variables 欄に直接貼り付けてください。
# ============================================================

# ── Cloudflare Tunnel 公開 URL ────────────────────────────────────────────────
# 別スタックで動かす Cloudflare Tunnel の公開ドメインを設定してください。
# ポータルサイトの VRChat URL 表示に使用します。
# 未設定の場合はローカル IP ベースの URL を表示します。
SITE_BASE_URL=https://stream.example.com

# ── ngrok 認証 (RTMP 公開用) ─────────────────────────────────────────────────
# https://dashboard.ngrok.com/get-started/your-authtoken で取得
NGROK_AUTHTOKEN=your_ngrok_authtoken_here

# ngrok RTMP トンネルのターゲット (network_mode: host なので localhost を使用)
NGROK_RTMP_TARGET=127.0.0.1:1935

# FastAPI が ngrok API を参照する内部 URL
NGROK_RTMP_API=http://127.0.0.1:4040

# ngrok URL のキャッシュ有効時間 (秒)
NGROK_CACHE_TTL=30

# ── RTMP Ingest ──────────────────────────────────────────────────────────────
RTMP_PORT=1935

# ── NVENC エンコード (ABR VBR) ────────────────────────────────────────────────
# VIDEO_BITRATE: high レンダリングの平均ビットレート (maxrate は自動で 1.35 倍)
# VIDEO_BITRATE_LOW: low レンダリング (720p) の平均ビットレート
# VIDEO_FPS_LOW: low レンダリング (720p) の固定FPS。30は低負荷、60は滑らかさ優先。
# AUDIO_BITRATE: high レンダリングの音声上限。low は 128k 固定。
# GTX1650 の実用上限: VIDEO_BITRATE=8000k 程度 (NVENC 2セッション使用)
VIDEO_BITRATE=6000k
VIDEO_BITRATE_LOW=2000k
VIDEO_FPS_LOW=30
AUDIO_BITRATE=320k

# ── LL-HLS チューニング ───────────────────────────────────────────────────────
# セグメント長 (秒): 小さいほど低遅延・負荷増。PC/Android 共通
HLS_SEGMENT_TIME=0.5
# パーツ長 (秒): PC 向け LL-HLS の最小配信単位
HLS_PART_DURATION=0.1
# プレイリスト保持セグメント数
HLS_LIST_SIZE=6

# ── API Server ────────────────────────────────────────────────────────────────
# network_mode: host のためポートマッピング不要。ホストの :8080 で直接公開される。
API_PORT=8080
LOG_LEVEL=info              # debug / info / warning / error

# api-server が MediaMTX のHLSエンドポイントから LL-HLS プレイリストを取得する内部URL
MEDIAMTX_HLS_URL=http://127.0.0.1:8888
MEDIAMTX_HLS_TIMEOUT=1.0

# ── 同時接続制限 ──────────────────────────────────────────────────────────────
# MAX_SESSIONS : 同時視聴上限。超過した新規接続は空き枠が出るまでキュー待機。
# SESSION_TIMEOUT : 最終リクエストから N 秒後にセッション自動消滅 (秒)。
# QUEUE_TIMEOUT   : キュー待機タイムアウト。超えると 503 を返す (秒)。
# MAX_BPS         : セッション毎の1秒あたり最大受信バイト数。
#                   HLS は起動時に複数セグメントをバーストDLするため、
#                   動画ビットレートの3倍以上を推奨。
#                   6Mbps high / 2Mbps low なら 3MB/s (24Mbps) が目安。
#                   超過したセッションは即時強制終了 (429 を返す)。
MAX_SESSIONS=100
SESSION_TIMEOUT=8.0
QUEUE_TIMEOUT=20.0
MAX_BPS=3000000

# ── 署名付きセグメント / LL-HLS preload 待機 ────────────────────────────────
# SEGMENT_WAIT_TIMEOUT : LL-HLS の PRELOAD-HINT が未生成 part を先読みした時に待つ秒数。
#                        通常の遅延を増やす設定ではなく、早すぎる segment 要求の 404 を防ぎます。
SEGMENT_SECRET=
SEGMENT_TTL=120
SEGMENT_WAIT_TIMEOUT=1.5
TOKEN_TTL=60

# ── Docker 共通 ───────────────────────────────────────────────────────────────
RESTART_POLICY=unless-stopped

# ── GPU (通常は変更不要) ──────────────────────────────────────────────────────
GPU_COUNT=1

# ── ヘルスチェック (通常は変更不要) ──────────────────────────────────────────
HC_INTERVAL=10s
HC_TIMEOUT=5s
HC_RETRIES=3

# ── コンテナ名 (複数スタックを同一ホストで動かす場合に変更) ─────────────────
MEDIA_CONTAINER=sycs-media-server
API_CONTAINER=sycs-api-server
NGROK_RTMP_CONTAINER=sycs-ngrok-rtmp
